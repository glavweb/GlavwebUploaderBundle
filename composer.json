        "symfony/finder": "^8.0",
        "symfony/translation": "^8.0",
        "symfony/translation-contracts": "^3.7",
        "symfony/mime": "^8.0",
        "symfony/routing": "^8.0",
        "symfony/event-dispatcher": "^8.0",
        "doctrine/orm": "^3.3",
